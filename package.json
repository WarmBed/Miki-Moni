{
  "name": "cc-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build:web": "vite build",
    "build:phone": "vite build --config vite-phone.config.ts",
    "build:all": "pnpm build:web && pnpm build:phone",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "install:hooks": "tsx src/install-hooks.ts",
    "pair": "tsx src/cli/pair.ts",
    "cch": "tsx src/cli/cch.ts",
    "wrap": "tsx src/cli/wrap.ts",
    "mock-worker": "tsx tools/mock-worker/server.ts",
    "dev:all": "tsx tools/dev/start-all.ts",
    "verify": "tsx tools/dev/verify-relay.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.143",
    "better-sqlite3": "^11.3.0",
    "express": "^5.0.0",
    "marked": "^18.0.3",
    "node-notifier": "^10.0.1",
    "pino": "^9.4.0",
    "qrcode-terminal": "^0.12.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^20.16.0",
    "@types/node-notifier": "^8.0.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "preact": "^10.24.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
